# Butlr MCP Server Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# Required: Butlr API credentials (OAuth2 Client Credentials)
BUTLR_CLIENT_ID=your_client_id_here
BUTLR_CLIENT_SECRET=your_client_secret_here

# Optional: Organization ID (auto-detected if not set)
BUTLR_ORG_ID=your_organization_id_here

# Optional: API configuration
BUTLR_BASE_URL=https://api.butlr.io
BUTLR_TIMEZONE=UTC

# Optional: MCP server configuration
MCP_CACHE_TOPO_TTL=600
MCP_MAX_IDS=100
MCP_MAX_LOOKBACK_DAYS=90
MCP_CONCURRENCY=5

# Optional: Tool selection (comma-separated) - planned, not yet implemented
# BUTLR_TOOLSETS=occupancy,topology,devices

# Optional: Debug and telemetry
DEBUG=butlr-mcp
BUTLR_MCP_ANALYTICS=false
