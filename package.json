{
  "name": "@butlr/butlr-mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server providing secure, read-only access to Butlr occupancy and asset data",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "butlr-mcp": "./bin/cli.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:debug": "DEBUG=butlr-mcp tsx src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "fixtures": "tsx scripts/snapshot-api-responses.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "butlr",
    "occupancy",
    "sensor",
    "graphql",
    "api"
  ],
  "author": "Butlr",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@apollo/client": "^4.0.7",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "graphql": "^16.11.0",
    "lru-cache": "^11.0.2",
    "undici": "^7.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
